<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Openminded.Avalonia.App.MainWindow"
        Title="Openminded.Avalonia.App">
    <StackPanel Orientation="Horizontal" Background="Aqua">
        <StackPanel Orientation="Vertical" Height="100" Background="Blue"/>
        <StackPanel Orientation="Vertical" Background="Beige"/>
        <StackPanel Orientation="Vertical" Background="Brown"/>
    </StackPanel>
</Window>
